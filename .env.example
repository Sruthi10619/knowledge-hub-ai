# ==============================================================================
# KNOWLEDGE HUB AI - SYSTEM ENVIRONMENT CONFIGURATION (EXAMPLE)
# ==============================================================================
# Copy this file to '.env' and populate appropriate API credentials.

# --- CORE SETTINGS ---
APP_NAME="Knowledge Hub AI"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Multi-Tenant isolated RAG Knowledge Base and streaming conversational platform."
DEBUG=True
SECRET_KEY="replace-this-with-a-very-secure-random-bytes-key-for-jwt"

# --- DATABASE CONFIGURATION ---
# Default async connection settings for SQLite database (local)
DATABASE_URL="sqlite+aiosqlite:///backend/data/knowledgehub.db"

# --- RATE LIMITING ---
RATE_LIMIT_PER_MINUTE=60

# --- LLM PROVIDER CREDENTIALS ---
# App defaults to Groq provider for ultra-fast free inferences. Enable your provider of choice:
DEFAULT_LLM_PROVIDER="groq"

GROQ_API_KEY="gsk_..."
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
HF_API_TOKEN=""

